# ==========================================
# 1. Jupyter Notebooks & Python
# ==========================================
# Jupyter Notebook checkpoints and autosaves
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (if you use venv, conda, or poetry locally)
.venv/
venv/
env/
ENV/
.pytest_cache/
.poetry/

# Data files (Highly recommended for ML/Data Science)
# Prevents accidentally pushing massive datasets to GitHub
*.csv
*.json
*.parquet
*.h5
*.pkl
*.pickle
data/

# ==========================================
# 2. Rust
# ==========================================
# The "target" directory holds all compiled binaries and build artifacts.
# This gets massive quickly and should never be committed.
/target/

# Backup files generated by cargo (rare, but good to have)
**/*.rs.bk

# ==========================================
# 3. Editor & IDEs (VS Code)
# ==========================================
# VS Code local settings, history, and workspace configurations
.vscode/
!.vscode/extensions.json
.history/

# ==========================================
# 4. OS Specific
# ==========================================
.DS_Store
Thumbs.db